---
// PasswordChecker.astro - 密码强度检查器组件
// 使用 zxcvbn-ts 进行密码强度分析和泄露检测
---

<div id="pw-root">
  <!-- 输入区域 -->
  <div class="input-section">
    <fluent-label>輸入密碼</fluent-label>
    <div class="input-wrapper">
      <input
        type="password"
        id="pw-input"
        class="pw-input"
        placeholder="請輸入要檢測的密碼..."
        autocomplete="off"
      />
      <fluent-button id="pw-toggle" appearance="transparent" icon-only>
        <i class="bi bi-eye" slot="start"></i>
      </fluent-button>
    </div>
  </div>

  <!-- 强度显示 -->
  <div id="pw-strength-section" class="hidden">
    <!-- 强度评分 -->
    <div class="strength-row">
      <fluent-text size="200" class="label-text">強度評分</fluent-text>
      <div class="strength-info">
        <fluent-progress-bar id="pw-progress" min="0" max="4"></fluent-progress-bar>
        <fluent-badge id="pw-badge" appearance="filled">--</fluent-badge>
      </div>
    </div>

    <!-- 破译时间 -->
    <div class="info-row crack-times">
      <div class="info-item">
        <i class="bi bi-clock info-icon"></i>
        <div class="crack-times-content">
          <div class="info-label">預估破譯時間</div>
          <div id="pw-crack-online-slow" class="crack-time-item">
            <span class="crack-scenario">線上限速攻擊</span>
            <span class="crack-value">--</span>
          </div>
          <div id="pw-crack-online-fast" class="crack-time-item">
            <span class="crack-scenario">線上無限速攻擊</span>
            <span class="crack-value">--</span>
          </div>
          <div id="pw-crack-offline-slow" class="crack-time-item">
            <span class="crack-scenario">離線慢速雜湊</span>
            <span class="crack-value">--</span>
          </div>
          <div id="pw-crack-offline-fast" class="crack-time-item">
            <span class="crack-scenario">離線快速雜湊</span>
            <span class="crack-value">--</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 泄露状态 -->
    <div class="info-row">
      <div class="info-item">
        <i id="pw-pwned-icon" class="bi bi-shield-check info-icon success"></i>
        <div>
          <div class="info-label">資料外洩檢測</div>
          <div id="pw-pwned-status" class="info-value">檢測中...</div>
        </div>
      </div>
    </div>

    <!-- 检测到的模式 -->
    <div id="pw-patterns-section" class="patterns-section hidden">
      <fluent-text size="200" class="label-text">檢測到的模式</fluent-text>
      <ul id="pw-patterns-list" class="patterns-list"></ul>
    </div>

    <!-- 改进建议 -->
    <div id="pw-suggestions-section" class="suggestions-section hidden">
      <fluent-text size="200" class="label-text">改進建議</fluent-text>
      <ul id="pw-suggestions-list" class="suggestions-list"></ul>
    </div>
  </div>
</div>

<script>
  import { zxcvbnAsync, zxcvbnOptions, type ZxcvbnResult } from "@zxcvbn-ts/core";
  import { matcherPwnedFactory } from "@zxcvbn-ts/matcher-pwned";
  import { dictionary as commonDict, adjacencyGraphs } from "@zxcvbn-ts/language-common";
  import { dictionary as enDict } from "@zxcvbn-ts/language-en";

  // 中文翻译
  const zhTranslations = {
    warnings: {
      straightRow: "鍵盤上的直排按鍵很容易被猜到。",
      keyPattern: "短鍵盤模式很容易被猜到。",
      simpleRepeat: "重複字符如「aaa」很容易被猜到。",
      extendedRepeat: "重複字符模式如「abcabcabc」很容易被猜到。",
      sequences: "常見字符序列如「abc」很容易被猜到。",
      recentYears: "近期年份很容易被猜到。",
      dates: "日期很容易被猜到。",
      topTen: "這是一個極度常見的密碼。",
      topHundred: "這是一個非常常見的密碼。",
      common: "這是一個常見密碼。",
      similarToCommon: "這與常見密碼相似。",
      wordByItself: "單個單詞很容易被猜到。",
      namesByThemselves: "單獨的名字或姓氏很容易被猜到。",
      commonNames: "常見的名字和姓氏很容易被猜到。",
      userInputs: "不應包含任何個人 or 頁面相關資料。",
      pwned: "您的密碼已在網路資料外洩事件中曝光。",
    },
    suggestions: {
      l33t: "避免可預測的字母替換，如用「@」代替「a」。",
      reverseWords: "避免常見單詞的反向拼寫。",
      allUppercase: "將部分字母大寫，但不要全部大寫。",
      capitalization: "大寫首字母以外的字母。",
      dates: "避免與您相關的日期和年份。",
      recentYears: "避免使用近期年份。",
      associatedYears: "避免與您相關的年份。",
      sequences: "避免常見字符序列。",
      repeated: "避免重複單詞和字符。",
      longerKeyboardPattern: "使用更長的鍵盤模式並多次改變輸入方向。",
      anotherWord: "加入更多不常見的單詞。",
      useWords: "使用多個單詞，但避免常見短語。",
      noNeed: "您可以不使用符號、數字或大寫字母來創建強密碼。",
      pwned: "如果您在其他地方使用此密碼，應該立即更改。",
    },
    timeEstimation: {
      ltSecond: "少於一秒",
      second: "{base} 秒",
      seconds: "{base} 秒",
      minute: "{base} 分鐘",
      minutes: "{base} 分鐘",
      hour: "{base} 小時",
      hours: "{base} 小時",
      day: "{base} 天",
      days: "{base} 天",
      month: "{base} 個月",
      months: "{base} 個月",
      year: "{base} 年",
      years: "{base} 年",
      centuries: "數百年",
    },
  };

  let initialized = false;

  function initZxcvbn() {
    if (initialized) return;

    const options = {
      dictionary: {
        ...commonDict,
        ...enDict,
      },
      graphs: adjacencyGraphs,
      useLevenshteinDistance: true,
      translations: zhTranslations,
    };

    // 设置选项
    zxcvbnOptions.setOptions(options);

    // 添加 Have I Been Pwned 检测（需要传入 options）
    const matcherPwned = matcherPwnedFactory(fetch, zxcvbnOptions);
    zxcvbnOptions.addMatcher("pwned", matcherPwned);

    initialized = true;
  }

  // 立即初始化
  initZxcvbn();

  // UI 元素引用
  const input = document.getElementById("pw-input") as HTMLInputElement;
  const toggle = document.getElementById("pw-toggle") as HTMLElement;
  const strengthSection = document.getElementById("pw-strength-section") as HTMLElement;
  const progress = document.getElementById("pw-progress") as HTMLElement;
  const badge = document.getElementById("pw-badge") as HTMLElement;
  const crackOnlineSlow = document.getElementById("pw-crack-online-slow") as HTMLElement;
  const crackOnlineFast = document.getElementById("pw-crack-online-fast") as HTMLElement;
  const crackOfflineSlow = document.getElementById("pw-crack-offline-slow") as HTMLElement;
  const crackOfflineFast = document.getElementById("pw-crack-offline-fast") as HTMLElement;
  const pwnedIcon = document.getElementById("pw-pwned-icon") as HTMLElement;
  const pwnedStatus = document.getElementById("pw-pwned-status") as HTMLElement;
  const patternsSection = document.getElementById("pw-patterns-section") as HTMLElement;
  const patternsList = document.getElementById("pw-patterns-list") as HTMLElement;
  const suggestionsSection = document.getElementById("pw-suggestions-section") as HTMLElement;
  const suggestionsList = document.getElementById("pw-suggestions-list") as HTMLElement;

  // 强度等级配置
  const strengthConfig: Record<number, { label: string; color: string; cls: string }> = {
    0: { label: "非常弱", color: "var(--colorPaletteRedForeground1)", cls: "weak" },
    1: { label: "弱", color: "var(--colorStatusWarningForeground)", cls: "weak" },
    2: { label: "一般", color: "var(--colorBrandForeground1)", cls: "medium" },
    3: { label: "強", color: "var(--colorStatusSuccessForeground)", cls: "strong" },
    4: { label: "非常強", color: "var(--colorPaletteGreenForeground1)", cls: "strong" },
  };

  // 模式类型中文映射
  const patternNames: Record<string, string> = {
    dictionary: "字典單詞",
    spatial: "鍵盤模式",
    repeat: "重複字符",
    sequence: "序列模式",
    regex: "正則匹配",
    date: "日期模式",
    bruteforce: "暴力破解",
  };

  // 防抖函数
  function debounce<T extends (...args: unknown[]) => void>(fn: T, delay: number): T {
    let timer: ReturnType<typeof setTimeout>;
    return ((...args: unknown[]) => {
      clearTimeout(timer);
      timer = setTimeout(() => fn(...args), delay);
    }) as T;
  }

  // 更新单个破译时间项
  function updateCrackTimeItem(element: HTMLElement, timeStr: string, score: number) {
    const valueEl = element.querySelector(".crack-value") as HTMLElement;

    // 判断是否是长时间
    const isVeryLongTime =
      timeStr.includes("centuries") ||
      timeStr.includes("百年");

    let display = timeStr;
    let cls = "";

    if (isVeryLongTime || score >= 4) {
      cls = "success";
      if (timeStr.includes("centuries")) {
        display = "數百年以上";
      }
    } else if (score >= 3) {
      cls = "medium";
    } else {
      cls = "danger";
    }

    valueEl.textContent = display;
    valueEl.className = `crack-value ${cls}`;
  }

  // 更新 UI
  function updateUI(result: ZxcvbnResult | null) {
    if (!result) {
      strengthSection.classList.add("hidden");
      return;
    }

    strengthSection.classList.remove("hidden");

    // 更新进度条和徽章
    const score = result.score;
    const config = strengthConfig[score];

    progress.setAttribute("value", String(score));
    progress.style.setProperty("--accent-fill", config.color);
    badge.textContent = `${config.label} (${score}/4)`;
    badge.className = `badge-${config.cls}`;

    // 更新破译时间
    const crackTimes = result.crackTimesDisplay;

    // 更新各个场景的破译时间
    updateCrackTimeItem(crackOnlineSlow, crackTimes.onlineThrottling100PerHour, result.score);
    updateCrackTimeItem(crackOnlineFast, crackTimes.onlineNoThrottling10PerSecond, result.score);
    updateCrackTimeItem(crackOfflineSlow, crackTimes.offlineSlowHashing1e4PerSecond, result.score);
    updateCrackTimeItem(crackOfflineFast, crackTimes.offlineFastHashing1e10PerSecond, result.score);

    // 更新建议
    const feedback = result.feedback;
    if (feedback.suggestions.length > 0 || feedback.warning) {
      suggestionsSection.classList.remove("hidden");
      suggestionsList.innerHTML = "";

      if (feedback.warning) {
        const li = document.createElement("li");
        li.className = "warning";
        li.innerHTML = `<i class="bi bi-exclamation-triangle"></i> ${escapeHtml(feedback.warning)}`;
        suggestionsList.appendChild(li);
      }

      for (const suggestion of feedback.suggestions) {
        const li = document.createElement("li");
        li.innerHTML = `<i class="bi bi-lightbulb"></i> ${escapeHtml(suggestion)}`;
        suggestionsList.appendChild(li);
      }
    } else {
      suggestionsSection.classList.add("hidden");
    }

    // 更新检测到的模式
    if (result.sequence.length > 0) {
      patternsSection.classList.remove("hidden");
      patternsList.innerHTML = "";

      for (const pattern of result.sequence) {
        const li = document.createElement("li");
        const typeName = patternNames[pattern.pattern] || pattern.pattern;
        const token = escapeHtml(pattern.token);
        li.innerHTML = `<span class="pattern-type">${typeName}</span>: <code>${token}</code>`;
        patternsList.appendChild(li);
      }
    } else {
      patternsSection.classList.add("hidden");
    }
  }

  // 更新泄露状态
  function updatePwnedStatus(result: ZxcvbnResult | null) {
    if (!result) {
      pwnedStatus.textContent = "--";
      pwnedIcon.className = "bi bi-shield info-icon";
      return;
    }

    // 检查 feedback 中是否有 pwned 警告（翻译后的文本）
    const warning = result.feedback.warning || "";
    const hasPwnedWarning =
      warning === "pwned" ||
      warning.includes("資料外洩") ||
      warning.includes("data breach") ||
      warning.includes("exposed");

    // 检查 sequence 中是否有 pwned 匹配
    const pwnedMatch = result.sequence.find((p) => p.pattern === "pwned");

    if (hasPwnedWarning || pwnedMatch) {
      // 尝试获取泄露次数
      const pwnedData = pwnedMatch as any;
      const count = pwnedData?.pwnedCount || pwnedData?.data?.pwnedCount;

      if (count) {
        pwnedStatus.textContent = `已出現在資料外洩中 (${formatNumber(count)} 次)`;
      } else {
        pwnedStatus.textContent = "已出現在資料外洩中";
      }
      pwnedStatus.className = "info-value danger";
      pwnedIcon.className = "bi bi-shield-x info-icon danger";
    } else {
      pwnedStatus.textContent = "未在已知資料外洩中發現";
      pwnedStatus.className = "info-value success";
      pwnedIcon.className = "bi bi-shield-check info-icon success";
    }
  }

  // 格式化数字
  function formatNumber(num: number): string {
    if (num >= 1e9) return (num / 1e9).toFixed(1) + "B";
    if (num >= 1e6) return (num / 1e6).toFixed(1) + "M";
    if (num >= 1e3) return (num / 1e3).toFixed(1) + "K";
    return num.toString();
  }

  // HTML 转义
  function escapeHtml(text: string): string {
    const map: Record<string, string> = {
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#039;",
    };
    return text.replace(/[&<>"']/g, (c) => map[c]);
  }

  // 检查密码
  async function checkPassword(password: string) {
    if (!password) {
      updateUI(null);
      return;
    }

    try {
      // 使用异步方法以包含 pwned 检测
      const result = await zxcvbnAsync(password);
      updateUI(result);
      updatePwnedStatus(result);
    } catch (err) {
      console.error("Password check failed:", err);
      pwnedStatus.textContent = "無法檢測（網路錯誤）";
      pwnedStatus.className = "info-value warning";
      pwnedIcon.className = "bi bi-shield-exclamation info-icon warning";
    }
  }

  // 显示/隐藏密码
  toggle?.addEventListener("click", () => {
    const isPassword = input.type === "password";
    input.type = isPassword ? "text" : "password";
    const icon = toggle.querySelector("i");
    if (icon) {
      icon.className = isPassword ? "bi bi-eye-slash" : "bi bi-eye";
    }
  });

  // 输入监听（防抖）
  const debouncedCheck = debounce(checkPassword, 300);
  input?.addEventListener("input", () => {
    debouncedCheck(input.value);
  });
</script>

<style>
  #pw-root {
    max-width: 600px;
  }

  .hidden {
    display: none !important;
  }

  /* 输入区域 */
  .input-section {
    margin-bottom: 24px;
  }

  .input-section fluent-label {
    display: block;
    margin-bottom: 8px;
  }

  .input-wrapper {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .pw-input {
    flex: 1;
    padding: 10px 14px;
    background: var(--colorNeutralBackground3);
    border: 1px solid var(--colorNeutralStroke2);
    border-bottom: 2px solid var(--colorNeutralStroke1);
    color: var(--colorNeutralForeground1);
    font-family: var(--fontFamilyMono);
    font-size: 16px;
    border-radius: var(--borderRadiusSmall) var(--borderRadiusSmall) 0 0;
    transition: border-color var(--durationNormal) var(--curveEasyEase);
  }

  .pw-input:focus {
    outline: none;
    border-bottom-color: var(--colorBrandForeground1);
  }

  .pw-input::placeholder {
    color: var(--colorNeutralForeground4);
  }

  /* 强度显示 */
  .strength-row {
    margin-bottom: 20px;
  }

  .label-text {
    display: block;
    margin-bottom: 8px;
    color: var(--colorNeutralForeground3);
  }

  .strength-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .strength-info fluent-progress-bar {
    flex: 1;
    height: 8px;
  }

  :global(fluent-progress-bar) {
    --accent-fill: var(--colorBrandForeground1);
  }

  /* 徽章样式 */
  :global(fluent-badge) {
    min-width: 80px;
    text-align: center;
    justify-content: center;
  }

  :global(.badge-weak) {
    --badge-fill: var(--colorPaletteRedBackground1);
    --badge-color: var(--colorPaletteRedForeground1);
  }

  :global(.badge-medium) {
    --badge-fill: var(--colorBrandStroke2);
    --badge-color: var(--colorBrandForeground1);
  }

  :global(.badge-strong) {
    --badge-fill: var(--colorStatusSuccessBackground);
    --badge-color: var(--colorStatusSuccessForeground);
  }

  /* 信息行 */
  .info-row {
    margin-bottom: 16px;
    padding: 16px;
    background: var(--colorNeutralBackground3);
    border: 1px solid var(--colorNeutralStroke2);
    border-radius: var(--borderRadiusLarge);
    animation: slideUp 300ms var(--curveDecelerateMid) both;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .info-icon {
    font-size: 24px;
    line-height: 1;
  }

  .info-icon.success {
    color: var(--colorStatusSuccessForeground);
  }

  .info-icon.danger {
    color: var(--colorPaletteRedForeground1);
  }

  .info-icon.warning {
    color: var(--colorStatusWarningForeground);
  }

  .info-label {
    font-size: 12px;
    color: var(--colorNeutralForeground3);
    margin-bottom: 8px;
  }

  /* 破译时间样式 */
  .crack-times-content {
    flex: 1;
  }

  .crack-time-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    border-bottom: 1px solid var(--colorNeutralStroke2);
  }

  .crack-time-item:last-child {
    border-bottom: none;
  }

  .crack-scenario {
    font-size: 13px;
    color: var(--colorNeutralForeground3);
  }

  .crack-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--colorNeutralForeground1);
  }

  .crack-value.success {
    color: var(--colorStatusSuccessForeground);
  }

  .crack-value.medium {
    color: var(--colorBrandForeground1);
  }

  .crack-value.danger {
    color: var(--colorPaletteRedForeground1);
  }

  .info-value {
    font-size: 16px;
    font-weight: 600;
    color: var(--colorNeutralForeground1);
  }

  .info-value.success {
    color: var(--colorStatusSuccessForeground);
  }

  .info-value.medium {
    color: var(--colorBrandForeground1);
  }

  .info-value.danger {
    color: var(--colorPaletteRedForeground1);
  }

  .info-value.warning {
    color: var(--colorStatusWarningForeground);
  }

  /* 模式和建议列表 */
  .patterns-section,
  .suggestions-section {
    margin-top: 20px;
    padding: 16px;
    background: var(--colorNeutralBackground3);
    border: 1px solid var(--colorNeutralStroke2);
    border-radius: var(--borderRadiusLarge);
    animation: slideUp 300ms var(--curveDecelerateMid) both;
    animation-delay: 50ms;
  }

  .patterns-list,
  .suggestions-list {
    margin: 8px 0 0;
    padding-left: 20px;
    list-style: none;
  }

  .patterns-list li,
  .suggestions-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    color: var(--colorNeutralForeground2);
    font-size: 14px;
  }

  .patterns-list li i,
  .suggestions-list li i {
    font-size: 14px;
    color: var(--colorBrandForeground1);
  }

  .suggestions-list li.warning i {
    color: var(--colorStatusWarningForeground);
  }

  .pattern-type {
    color: var(--colorNeutralForeground3);
    font-size: 12px;
  }

  .patterns-list code {
    padding: 2px 6px;
    background: var(--colorNeutralBackground4);
    border-radius: 4px;
    font-family: var(--fontFamilyMono);
    font-size: 13px;
    color: var(--colorBrandForeground1);
  }

  @media (max-width: 768px) {
    #pw-root {
      padding: 0 8px;
    }

    .strength-info {
      flex-direction: column;
      align-items: stretch;
    }

    .strength-info fluent-badge {
      align-self: flex-end;
    }
  }
</style>