---
import PasswordChecker from "../components/PasswordChecker.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="密碼強度檢查器" description="檢測密碼強度、破譯時間和資料外洩狀態">
  <div class="page-header">
    <fluent-text size="600" weight="bold" block>密碼強度檢查器</fluent-text>
    <fluent-text size="200" class="subtitle">
      評估密碼安全性，檢測是否在資料外洩中出現
    </fluent-text>
  </div>

  <PasswordChecker />

  <div class="info-card">
    <fluent-text size="300" weight="semibold" block>
      <i class="bi bi-shield-lock"></i> 隱私說明
    </fluent-text>
    <ul class="privacy-list">
      <li>
        <strong>本地處理</strong>：密碼強度分析完全在瀏覽器中進行，不會發送到任何伺服器
      </li>
      <li>
        <strong>k-匿名性</strong>：外洩檢測僅發送密碼 SHA-1 雜湊值的前 5 個字元，密碼本身永遠不會離開您的裝置
      </li>
      <li>
        <strong>開源演算法</strong>：使用 Dropbox 的 zxcvbn 演算法，結合 Have I Been Pwned 資料庫
      </li>
    </ul>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 24px;
    animation: slideDown 300ms var(--curveDecelerateMid) both;
  }

  .subtitle {
    display: block;
    margin-top: 8px;
    color: var(--colorNeutralForeground3);
  }

  .info-card {
    margin-top: 32px;
    padding: 20px;
    background: var(--colorNeutralBackground3);
    border: 1px solid var(--colorNeutralStroke2);
    border-radius: var(--borderRadiusXLarge);
    animation: slideUp 300ms var(--curveDecelerateMid) both;
    animation-delay: 100ms;
  }

  .info-card fluent-text {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .info-card i {
    font-size: 18px;
    color: var(--colorBrandForeground1);
  }

  .privacy-list {
    margin: 0;
    padding-left: 20px;
    list-style: disc;
  }

  .privacy-list li {
    margin: 8px 0;
    color: var(--colorNeutralForeground2);
    font-size: 14px;
    line-height: 1.6;
  }

  .privacy-list strong {
    color: var(--colorNeutralForeground1);
  }
</style>